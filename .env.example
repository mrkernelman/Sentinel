DB_HOST=localhost
DB_PORT=5432
DB_NAME=shadow_it_db
DB_USER=postgres
DB_PASSWORD=<set-a-strong-password>
JWT_SECRET=<generate-a-long-random-secret>
JWT_EXPIRY_HOURS=8

# Cookie / transport hardening
# COOKIE_SECURE=true once served over HTTPS (see deploy/ TLS proxy).
# Leave false for plain http://localhost or browsers may drop the cookie.
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:3005

# Flask dev server only. NEVER set FLASK_DEBUG=true on an exposed host —
# the Werkzeug debugger is remote code execution. Production uses gunicorn.
FLASK_DEBUG=false
FLASK_PORT=5000
